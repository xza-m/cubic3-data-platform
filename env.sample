# ============================================================================
# CUBIC3 - 环境配置示例
# ============================================================================
# 
# 使用说明：
# 1. 复制此文件为 .env：cp env.sample .env
# 2. 根据实际环境修改配置值
# 3. 生产环境请使用 .env.prod 并确保敏感信息安全
#
# ============================================================================

# ============================================================================
# 数据库配置（必填）
# ============================================================================

# PostgreSQL 数据库连接 URI
# 格式：postgresql+psycopg2://用户名:密码@主机:端口/数据库名
# 示例：postgresql+psycopg2://postgres:postgres@localhost:5432/cubic3_data_platform
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/cubic3_data_platform

# SQLite 示例（仅用于开发测试）
# DATABASE_URL=sqlite:///instance/local.db

# ============================================================================
# Redis 配置（必填）
# ============================================================================

# Redis 连接 URL，用于任务队列和缓存
# 格式：redis://主机:端口/数据库编号
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Superset 集成配置（可选）
# ============================================================================

# Superset 基础 URL（用于截图功能）
SUPERSET_BASE_URL=https://superset.example.com

# 认证方式 1：用户名密码
SUPERSET_USERNAME=svc_user
SUPERSET_PASSWORD=secret

# 认证方式 2：JWT Token（推荐，与用户名密码二选一）
# SUPERSET_JWT=eyJhbGciOi...

# 超时和重试配置
SUPERSET_TIMEOUT=20                      # 请求超时时间（秒），默认 20
SUPERSET_RETRY_MAX=3                     # 最大重试次数，默认 3
SUPERSET_RETRY_BACKOFF=1.5               # 重试退避系数，默认 1.5

# 截图配置
SUPERSET_SCREENSHOT_MAX_WAIT=60          # 截图最大等待时间（秒），默认 60
SUPERSET_SCREENSHOT_POLL_INTERVAL=3      # 截图轮询间隔（秒），默认 3
SUPERSET_VIEWPORT_WIDTH=1920             # 视口宽度，默认 1920
SUPERSET_VIEWPORT_HEIGHT=1080            # 视口高度，默认 1080

# Dashboard URL 模板（如部署在子路径）
# SUPERSET_DASHBOARD_URL_TEMPLATE=/bi/superset/dashboard/{id}/

# ============================================================================
# 飞书集成配置（可选）
# ============================================================================

# 飞书应用凭证（在飞书开放平台创建应用后获取）
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# 默认飞书群聊 ID（应用机器人需已加入该群）
# 格式：oc_xxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_CHAT_ID=oc_xxx

# 飞书事件订阅验证 Token（在飞书开放平台配置事件订阅时设置）
FEISHU_VERIFICATION_TOKEN=

# 超时和重试配置
FEISHU_TIMEOUT=10                        # 请求超时时间（秒），默认 10
FEISHU_RETRY_MAX=3                       # 最大重试次数，默认 3
FEISHU_RETRY_BACKOFF=1.5                 # 重试退避系数，默认 1.5

# ============================================================================
# 阿里云 OSS 配置（可选，用于大文件交付）
# ============================================================================

# OSS 访问凭证
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# OSS 服务地址和存储桶
# 示例：oss-cn-hangzhou.aliyuncs.com
OSS_ENDPOINT=
OSS_BUCKET_NAME=

# ============================================================================
# LLM 配置（智能问数功能）
# ============================================================================

# LLM 提供商：openai | azure | custom
LLM_PROVIDER=openai

# OpenAI 配置
LLM_API_KEY=sk-your-openai-api-key-here
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=60                           # 请求超时时间（秒），默认 60

# OpenRouter 示例（可选，替代 OpenAI）
# LLM_PROVIDER=openrouter
# LLM_API_BASE=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-your-openrouter-key-here
# LLM_MODEL=openai/gpt-4o-mini

# Azure OpenAI 示例
# LLM_PROVIDER=azure
# LLM_API_BASE=https://your-resource.openai.azure.com/
# LLM_API_KEY=your-azure-api-key
# LLM_MODEL=gpt-4

# ============================================================================
# JWT 认证配置（必填）
# ============================================================================

# JWT 密钥（生产环境请使用强随机字符串）
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-secret-key-change-in-production-please

# JWT 过期时间（小时）
JWT_EXPIRATION_HOURS=24

# 管理员账号（备用登录方式，飞书 SSO 不可用时使用）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# 飞书管理员 open_id 列表（逗号分隔，这些用户飞书登录后自动获得 admin 角色）
# 获取方式：用户先飞书登录一次，在数据库或日志中查看其 open_id
# 示例：FEISHU_ADMIN_OPEN_IDS=ou_abc123,ou_def456
FEISHU_ADMIN_OPEN_IDS=

# ============================================================================
# 应用配置
# ============================================================================

# 应用基础 URL（用于生成外部链接）
APP_BASE_URL=http://localhost:5000

# 数据提取结果存储目录
EXTRACTION_RESULT_DIR=instance/extraction_results

# 文件上传配置
UPLOAD_FOLDER=instance/uploads           # 上传文件存储目录
MAX_CONTENT_LENGTH=52428800              # 最大上传大小（字节），默认 50MB
ALLOWED_EXTENSIONS=csv                   # 允许的文件扩展名（逗号分隔）

# ============================================================================
# 日志配置
# ============================================================================

# 日志级别：DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# 调度器配置（可选）
# ============================================================================

# 是否启用调度器 API
SCHEDULER_API_ENABLED=true

# 是否启用 APScheduler 定时任务注册（Worker 建议关闭）
ENABLE_SCHEDULER_JOBS=true

# ============================================================================
# dw-query-gateway 观测配置（可选）
# ============================================================================

# data-platform 只作为 gateway 观测 BFF，不在本仓内执行生产数仓查询。
# 生产 / 联调环境请指向实际 dw-query-gateway 服务；本地默认使用 compose 服务名。
QUERY_GATEWAY_BASE_URL=http://dw-query-gateway:8000

# 必须与 dw-query-gateway 侧 PLATFORM_SERVICE_TOKEN 保持一致。
# 不要把真实 token 写入仓库，请通过部署环境或密钥管理注入。
QUERY_GATEWAY_PLATFORM_SERVICE_TOKEN=

# gateway telemetry / readyz 请求超时（秒）
QUERY_GATEWAY_TIMEOUT_SECONDS=5

# ============================================================================
# 开发环境专用配置
# ============================================================================

# Flask 调试模式（生产环境必须设为 false）
# FLASK_DEBUG=false

# Flask 环境（development | production）
# FLASK_ENV=production

# ============================================================================
# 配置验证说明
# ============================================================================
#
# 本项目使用 Pydantic 进行配置验证，启动时会自动检查：
#
# 必填配置：
# - DATABASE_URL: 数据库连接 URI
# - REDIS_URL: Redis 连接 URL
# - JWT_SECRET: JWT 密钥
#
# 可选配置：
# - Superset: 如需截图功能，必须配置 SUPERSET_BASE_URL 和认证信息
# - 飞书: 如需飞书推送，必须配置 FEISHU_APP_ID 和 FEISHU_APP_SECRET
# - OSS: 如需 OSS 交付，必须配置所有 OSS_* 参数
# - LLM: 如需智能问数，必须配置 LLM_API_KEY
# - dw-query-gateway: 如需网关观测与告警，必须配置 QUERY_GATEWAY_PLATFORM_SERVICE_TOKEN
#
# 配置错误时，应用启动会失败并显示详细错误信息。
#
# ============================================================================
# 安全提示
# ============================================================================
#
# 1. 不要将 .env 文件提交到版本控制系统
# 2. 生产环境使用强随机密钥（JWT_SECRET）
# 3. 定期轮换敏感凭证（API Key、密码等）
# 4. 使用环境变量或密钥管理服务存储敏感信息
# 5. 限制 .env 文件的访问权限（chmod 600 .env）
#
# ============================================================================
