# 依赖目录（Docker 内部会重新安装）
node_modules

# 构建产物（会在容器内重新构建）
dist
build

# 日志
*.log
npm-debug.log*

# IDE
.vscode
.idea
*.swp
.DS_Store

# Git
.git
.gitignore

# 环境变量
.env
.env.local

# 测试覆盖率
coverage

# 本地测试与 Playwright 产物（生产 nginx 镜像不需要）
src/**/*.test.*
src/**/*.spec.*
tests
playwright-report*
test-results

# 缓存
.cache
.eslintcache
