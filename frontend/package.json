{
  "name": "cubic3-data-platform-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:visual": "playwright test tests/e2e-node/semantic.visual.spec.ts",
    "verify:semantic-layout": "npm exec -- tsc --noEmit --pretty false && npm run test:unit -- src/pages/Semantic/CubeList.page.test.tsx src/pages/Semantic/DomainList.page.test.tsx src/pages/Semantic/domainCanvasState.test.ts src/components/Semantic/workbench.test.tsx && playwright test tests/e2e-node/cube-browse.spec.ts tests/e2e-node/domain-creation.spec.ts tests/e2e-node/domain-catalog.spec.ts tests/e2e-node/domain-publish.spec.ts && npm run test:visual",
    "verify:ui": "npm exec -- tsc --noEmit --pretty false && npm run test:unit && npm run test:e2e",
    "e2e:domain-smoke": "python tests/e2e/domain_creation_smoke.py",
    "e2e:domain-publish-smoke": "python tests/e2e/domain_publish_smoke.py",
    "e2e:cube-draft-smoke": "python tests/e2e/cube_draft_smoke.py",
    "verify:semantic": "npm exec -- tsc --noEmit --pretty false && npm run build && DOMAIN_SMOKE_BASE_URL=${DOMAIN_SMOKE_BASE_URL:-http://127.0.0.1:3000} npm run e2e:domain-smoke && DOMAIN_SMOKE_BASE_URL=${DOMAIN_SMOKE_BASE_URL:-http://127.0.0.1:3000} npm run e2e:domain-publish-smoke && DOMAIN_SMOKE_BASE_URL=${DOMAIN_SMOKE_BASE_URL:-http://127.0.0.1:3000} npm run e2e:cube-draft-smoke"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@rjsf/core": "^5.24.13",
    "@rjsf/utils": "^5.24.13",
    "@rjsf/validator-ajv8": "^5.24.13",
    "@tanstack/react-query": "^5.17.9",
    "@tanstack/react-table": "^8.21.3",
    "@xyflow/react": "^12.10.1",
    "axios": "^1.6.5",
    "date-fns": "^3.6.0",
    "elkjs": "^0.11.1",
    "lucide-react": "^0.303.0",
    "overlayscrollbars": "^2.14.0",
    "overlayscrollbars-react": "^0.5.6",
    "react": "^18.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.21.1",
    "recharts": "^2.10.3",
    "sql-formatter": "^15.7.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.33",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vitest": "^3.2.4",
    "jsdom": "^26.1.0"
  }
}
