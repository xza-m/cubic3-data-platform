{
  "name": "cubic3-data-platform-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:v2": "vite --config v2.vite.config.ts",
    "build": "tsc && vite build",
    "build:v2": "tsc && vite build --config v2.vite.config.ts",
    "preview": "vite preview",
    "preview:v2": "vite preview --config v2.vite.config.ts",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "lint:css": "stylelint 'src/v2/**/*.css'",
    "check:v2-tokens": "node scripts/check-v2-tokens.mjs",
    "i18n:extract": "node scripts/i18n-extract.mjs",
    "i18n:populate": "node scripts/i18n-populate.mjs",
    "i18n:coverage": "node scripts/i18n-coverage.mjs",
    "lint:all": "npm run lint && npm run lint:css && npm run check:v2-tokens",
    "test:unit": "vitest run",
    "test:unit:coverage": "node -e \"require('fs').mkdirSync('coverage/.tmp', { recursive: true })\" && vitest run --coverage",
    "test:e2e:v2": "playwright test --config tests/e2e-v2/playwright.config.ts",
    "test:e2e:v2:smoke": "playwright test --config tests/e2e-v2/playwright.config.ts --grep \"@p01|@p02|@p03|@p07|@p21\"",
    "e2e:smoke": "playwright test --config tests/e2e-v2/playwright.config.ts smoke",
    "perf:lhci": "npm run build:v2 && cd .. && npx --yes @lhci/cli@0.15.x autorun --config=lighthouserc.json",
    "perf:lhci:assert": "cd .. && npx --yes @lhci/cli@0.15.x assert --config=lighthouserc.json",
    "e2e:domain-smoke": "node ./scripts/run-semantic-smoke.mjs tests/e2e/domain_creation_smoke.py",
    "e2e:domain-publish-smoke": "node ./scripts/run-semantic-smoke.mjs tests/e2e/domain_publish_smoke.py",
    "e2e:governance-issues-smoke": "node ./scripts/run-semantic-smoke.mjs tests/e2e/governance_issues_smoke.py",
    "e2e:data-assets-smoke": "node ./scripts/run-semantic-smoke.mjs tests/e2e/data_asset_foundation_smoke.py",
    "e2e:modeling-agent-smoke": "playwright test --config tests/e2e-v2/playwright.config.ts p34-modeling-agent-smoke.spec.ts",
    "e2e:modeling-agent-smoke:live": "P34_LIVE_API=1 playwright test --config tests/e2e-v2/playwright.config.ts p34-modeling-agent-live.spec.ts --workers=1",
    "ci:pre-push": "npm run lint && npm run test:unit && npm run build:v2",
    "prepare": "node -e \"try{require('child_process').execSync('git config core.hooksPath .husky',{cwd:'..',stdio:'ignore'})}catch(e){}\""
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings=0"
    ],
    "src/v2/**/*.css": [
      "stylelint --fix"
    ]
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@rjsf/core": "^5.24.13",
    "@rjsf/utils": "^5.24.13",
    "@rjsf/validator-ajv8": "^5.24.13",
    "@tanstack/react-query": "^5.17.9",
    "@tanstack/react-table": "^8.21.3",
    "@xyflow/react": "^12.10.1",
    "axios": "^1.6.5",
    "date-fns": "^3.6.0",
    "elkjs": "^0.11.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.303.0",
    "overlayscrollbars": "^2.14.0",
    "overlayscrollbars-react": "^0.5.6",
    "react": "^18.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.21.1",
    "recharts": "^2.10.3",
    "sql-formatter": "^15.7.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.53.2",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.2",
    "postcss": "^8.4.33",
    "stylelint": "^17.8.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-value-no-unknown-custom-properties": "^6.1.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vitest": "^3.2.4"
  }
}
