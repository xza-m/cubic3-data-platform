{
  "version": 1,
  "blocking_rules": [
    {
      "name": "workflow-verification",
      "description": "默认命令、验证入口或开发工作流变化后，必须同步更新对应运行或验证文档。",
      "patterns": [
        "Makefile",
        "scripts/checks/changed_validation.py",
        "scripts/verify_rules.json",
        "frontend/package.json",
        "frontend/vite.config.ts",
        "frontend/vitest.config.ts",
        "frontend/playwright.config.ts"
      ],
      "required_any_docs": [
        "docs/quality/testing.md",
        "docs/runbooks/local-dev.md",
        "README.md",
        "docs/QUICK_START.md",
        "docs/STARTUP_GUIDE.md",
        "frontend/README.md",
        "docs/DOC_ALIGNMENT_REPORT.md"
      ]
    },
    {
      "name": "startup-runtime",
      "description": "启动方式、运行拓扑或本地环境变化后，必须同步更新启动与运行文档。",
      "patterns": [
        "docker-compose.yml",
        "Dockerfile",
        "env.sample",
        "deploy.sh",
        "entrypoint.sh",
        "wsgi.py",
        "run_worker.py",
        "start_rq_worker.sh",
        "app/infrastructure/scheduler.py",
        "app/application/services/app_center/scheduler_service.py",
        "app/infrastructure/tasks/rq_worker.py",
        "app/infrastructure/tasks/task_queue.py"
      ],
      "required_any_docs": [
        "docs/runbooks/local-dev.md",
        "README.md",
        "docs/QUICK_START.md",
        "docs/STARTUP_GUIDE.md",
        "frontend/README.md",
        "docs/DOC_ALIGNMENT_REPORT.md"
      ]
    }
  ],
  "advisory_rules": [
    {
      "name": "architecture-boundary",
      "description": "行为边界、source of truth 或系统主入口变化后，应人工确认架构文档是否需要同步。",
      "patterns": [
        "app/__init__.py",
        "app/config_schema.py",
        "app/di/container.py",
        "app/interfaces/api/v1/*.py",
        "frontend/src/App.tsx",
        "frontend/src/main.tsx"
      ],
      "suggested_docs": [
        "docs/TECH_STACK_AND_ARCHITECTURE.md",
        "docs/architecture/README.md",
        "docs/architecture/backend.md",
        "docs/architecture/frontend.md",
        "docs/DOC_ALIGNMENT_REPORT.md"
      ]
    }
  ]
}
