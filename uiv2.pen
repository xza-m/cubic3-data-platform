                      "padding": [
                        0,
                        12
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "aCuv7",
                          "name": "c1",
                          "fill": "#93C5FD",
                          "content": "SELECT",
                          "lineHeight": 1.7,
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "u8bkr",
                          "name": "c2",
                          "fill": "#E2E8F0",
                          "content": "  o.order_id, o.status,",
                          "lineHeight": 1.7,
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "gJKLo",
                          "name": "c3",
                          "fill": "#E2E8F0",
                          "content": "  c.name AS customer_name,",
                          "lineHeight": 1.7,
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "zhG9A",
                          "name": "c4",
                          "fill": "#E2E8F0",
                          "content": "  SUM(o.total_amount) AS revenue",
                          "lineHeight": 1.7,
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "7xys7",
                          "name": "c5",
                          "fill": "#93C5FD",
                          "content": "FROM public.orders o",
                          "lineHeight": 1.7,
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "RqQ97",
                          "name": "c6",
                          "fill": "#93C5FD",
                          "content": "LEFT JOIN public.customers c ON o.user_id = c.id",
                          "lineHeight": 1.7,
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "LgwWE",
                          "name": "c7",
                          "fill": "#93C5FD",
                          "content": "WHERE o.created_at >= '{{start_date}}'",
                          "lineHeight": 1.7,
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "uA3Iq",
                          "name": "c8",
                          "fill": "#93C5FD",
                          "content": "GROUP BY o.order_id, o.status, c.name",
                          "lineHeight": 1.7,
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
                },
